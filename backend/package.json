{
  "name": "app-financeiro-backend",
  "version": "1.1.0",
  "description": "App Financeiro - NestJS Backend",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Thom3002/app-financeiro.git"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "start:electron": "npm run build && electron .",
    "verify-builds": "node scripts/verify-builds.js",
    "predist": "npm run verify-builds",
    "prepack": "npm run verify-builds",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "prepare": "cd .. && husky backend/.husky"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/typeorm": "^10.0.2",
    "better-sqlite3": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.5.6",
    "electron-updater": "^6.8.3",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0",
    "wait-on": "^9.0.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  },
  "main": "desktop/main.js",
  "build": {
    "appId": "com.thomasdemello.appfinanceiro",
    "productName": "App Financeiro",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Thom3002",
        "repo": "app-financeiro"
      }
    ],
    "files": [
      "!**/*",
      "desktop/main.js",
      "dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "node_modules/better-sqlite3",
        "to": "app/node_modules/better-sqlite3",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
